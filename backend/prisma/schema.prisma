generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StatusAtendimento {
  PENDENTE
  CONFIRMADO
  REALIZADO
  CANCELADO
}

model Cliente {
  id               String   @id @default(uuid())
  nome             String
  email            String   @unique
  telefone         String
  cpf              String?  @unique
  dataNascimento   DateTime?
  observacoes      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  atendimentos     Atendimento[]
}

model Profissional {
  id               String   @id @default(uuid())
  nome             String
  email            String   @unique
  telefone         String
  especialidade    String
  ativo            Boolean  @default(true)
  horaInicio      String   @default("09:00")
  horaFim         String   @default("18:00")

  intervaloInicio String?  @default("12:00")
  intervaloFim    String?  @default("13:00")

  diasAtivos      String   @default("1,2,3,4,5")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  atendimentos     Atendimento[]
}

model Procedimento {
  id               String   @id @default(uuid())
  nome             String
  descricao        String?
  categoria        String
  preco            Float
  duracao          Int
  ativo            Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  atendimentos     AtendimentoProcedimento[]
}

model Atendimento {
  id               String            @id @default(uuid())
  data             DateTime
  status           StatusAtendimento @default(PENDENTE)
  observacoes      String?
  valorTotal       Float             @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  clienteId        String
  cliente          Cliente           @relation(fields: [clienteId], references: [id])

  profissionalId   String
  profissional     Profissional      @relation(fields: [profissionalId], references: [id])

  procedimentos    AtendimentoProcedimento[]
}

model AtendimentoProcedimento {
  id               String @id @default(uuid())

  atendimentoId    String
  procedimentoId   String

  atendimento      Atendimento  @relation(fields: [atendimentoId], references: [id])
  procedimento     Procedimento @relation(fields: [procedimentoId], references: [id])
}

model Usuario {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  resetToken        String?
  resetTokenExpires DateTime?
}